# Base image for the 'private' build target.
# "base" = build everything locally | GHCR image = pull pre-built public image
BASE_IMAGE=ghcr.io/matuscvengros/claude-sandbox:latest

# --- Build ---
# Build target: "base" (public only) or "private" (public + private plugins)
BUILD_TARGET=private

# --- Authentication ---
# OAuth token via environment variable
# Get from 'claude setup-token' or copy from an existing session
CLAUDE_CODE_OAUTH_TOKEN=

# --- GitHub ---
# Same token can be used for both, but you can also use separate ones if you prefer
# For gh commands
GITHUB_TOKEN=
# For MCP server installed as a plugin (see Dockerfile)
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- Optional: SSH ---
# SSH agent forwarding is enabled by default (uses host's ssh-agent).
# If your host has no agent, provide a base64-encoded private key as fallback:
# Generate with: base64 -i ~/.ssh/id_ed25519
SSH_PRIVATE_KEY_B64=

# --- Git identity ---
GIT_USER_NAME=
GIT_USER_EMAIL=
