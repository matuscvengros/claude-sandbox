{
  "name": "Claude Code Sandbox (DevContainer)",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": "..",
    "target": "${localEnv:BUILD_TARGET:base}"
  },
  "overrideCommand": true,
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/claude/${localWorkspaceFolderBasename},type=bind",
  "workspaceFolder": "/home/claude/${localWorkspaceFolderBasename}",
  "remoteUser": "claude",
  "remoteEnv": {
    "HOME": "/home/claude"
  },
  "containerEnv": {
    "SSH_AUTH_SOCK": "/ssh-agent"
  },
  "mounts": [
    "source=${localEnv:SSH_AUTH_SOCK:/dev/null},target=/ssh-agent,type=bind,readonly"
  ],
  "runArgs": [
    "--env-file", "${localWorkspaceFolder}/.env"
  ],
  "postStartCommand": "/bin/bash ${containerWorkspaceFolder}/.devcontainer/post-start.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "ms-python.python",
        "rust-lang.rust-analyzer",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
